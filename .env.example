# MongoDB (local dev or Atlas in production)
MONGODB_URI=mongodb://127.0.0.1:27017/parking-at-boulevard

# Cron (Vercel injects Authorization: Bearer when set)
CRON_SECRET=replace-with-long-random-string

# Dashboard login
DASHBOARD_PASSWORD=replace-with-strong-password
# Optional; defaults to CRON_SECRET if unset
SESSION_SECRET=replace-with-long-random-string

# Business
TZ_DISPLAY=America/Los_Angeles
MONTHLY_HOUR_CAP=168
REGISTRATION_DURATION_HOURS=5

# Random minute window within LA hour 2 (2:00–2:55)
SCHEDULE_LA_WINDOW_START_MINUTE=0
SCHEDULE_LA_WINDOW_END_MINUTE=55

# Cron: `hobby` (default) = Vercel Hobby one run/day, no random-minute wait. `pro` = multi-tick + random minute (needs Vercel Pro cron).
# CRON_SCHEDULE_MODE=hobby

# --- Parking Attendant / PropertyBoss (boulevard.parkingattendant.com) ---

# Site (no trailing slash)
PARKING_BASE_URL=https://boulevard.parkingattendant.com

# From URL: /{tenant}/permits/new?policy=...&media=...
PARKING_TENANT_SLUG=
PARKING_POLICY_ID=
# Query param `media=` (site media / context id — not always the same as Smart Decal digits)
PARKING_MEDIA_ID=

# JSON API used by the app (HTML references this host)
PARKING_API_BASE_URL=https://api.propertyboss.io

# Activate Smart Decal — form field name="media" (numeric decal)
PARKING_SMART_DECAL_NUMBER=

# License plate — form field name="vehicle"
PARKING_VEHICLE_PLATE=

# Resident passcode (auth fieldsets on Unlock / Check usage flows)
PARKING_PASSCODE=

# “Home” / unit / visiting line — tenant fieldsets (`visiting tenant account`, etc.)
PARKING_HOME=

# Hidden field name="location" when required — copy value from browser Network if present
PARKING_LOCATION_ID=

# Optional: email / name if your HAR shows account/authorize or contact steps
PARKING_EMAIL=
PARKING_CONTACT_NAME=

# ISO-8601 permit length (e.g. PT5H). Together with viewpoint=LA midnight, five hours means midnight–5:00am LA.
# If unset, derived from REGISTRATION_DURATION_HOURS (e.g. 5 -> PT5H).
# PARKING_LIFETIME_ISO=PT5H

# Browser Cookie header for authenticated requests (export after login in DevTools)
PARKING_COOKIE=

# Optional Bearer if the API uses Authorization: Bearer (from HAR)
# PARKING_BEARER_TOKEN=

# After successful POST /v1/permits/temporary, the site POSTs /v1/send to email the receipt.
# Copy `container=` from that Network request. Requires PARKING_EMAIL. Same Cookie/Bearer as registration.
# PARKING_SEND_CONTAINER=
# Optional path if your tenant uses a different send endpoint (default: v1/send)
# PARKING_SEND_PATH=v1/send
# PARKING_SKIP_SEND=false

# --- Registration POST (copy Request URL from DevTools Network after a successful submit) ---
# Full POST URL (wins over RELATIVE_PATH if both set). If the URL contains `duration=` or `viewpoint=`,
# the app sets duration from PARKING_LIFETIME_ISO / REGISTRATION_DURATION_HOURS and viewpoint to LA midnight
# for the current LA calendar day (so e.g. PT5H = 12:00am–5:00am LA).
# PARKING_POST_URL=

# Or only the path after /{tenant}/ on api.propertyboss.io (no leading slash)
# PARKING_POST_RELATIVE_PATH=

# Optional JSON body; placeholders: {{VEHICLE}} {{PASSCODE}} {{HOME}} {{SMART_DECAL}} {{LOCATION}} {{LIFETIME}} {{POLICY}} {{MEDIA_QUERY}} {{TENANT}} {{EMAIL}} {{CONTACT_NAME}} {{VIEWPOINT}}
# If omitted, default JSON is built in lib/parking-post.ts
# PARKING_POST_BODY_JSON=

# Skip loading the HTML permit page; only send POST (after POST URL is configured)
# PARKING_SKIP_PAGE_GET=false

# If true (default), require SMART_DECAL, VEHICLE, PASSCODE, HOME before running.
# Set to false to only check URL params while wiring HAR.
# PARKING_REQUIRE_FULL_FORM=true

# Dry-run: records success without calling the parking site
# SKIP_PARKING_REGISTRATION=true
